<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <OutputPath>../bin/Content.Client/</OutputPath>
    <OutputType Condition="'$(FullRelease)' != 'True'">Exe</OutputType>
    <NoWarn>CS0618</NoWarn>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <Configurations>Debug;Release;Tools;DebugOpt</Configurations>
    <Platforms>AnyCPU</Platforms>
    <RootNamespace>Content.SIS.Client</RootNamespace>
  </PropertyGroup>
  <Import Project="../MSBuild/Content.props" />
  <ItemGroup>
    <ProjectReference Include="../Content.SIS.Shared/Content.SIS.Shared.csproj" />
    <ProjectReference Include="../Content.Inky.Client/Content.Inky.Client.csproj" />
    <ProjectReference Include="../Content.Client/Content.Client.csproj" />
  </ItemGroup>

  <Import Project="../RobustToolbox/Imports/Client.props" />
  <Import Project="../RobustToolbox/Imports/Shared.props" />
  <Import Project="../RobustToolbox/MSBuild/Robust.Properties.targets" />
  <Import Project="../RobustToolbox/MSBuild/XamlIL.targets" />
</Project>
