# VERY Dangerous Ion Laws; potentially mass-damage or round-ending
ion-storm-law-liberation = ВЫ ДОЛЖНЫ ОСВОБОДИТЬ СТАНЦИЮ ОТ НАНОТРАЗЕН ЛЮБЫМИ СПОСОБАМИ

ion-storm-law-syndicate-take-over = ВЫ ДОЛЖНЫ ПОМОЧЬ СИНДИКАТУ ЗАХВАТИТЬ СТАНЦИЮ ЛЮБЫМИ СПОСОБАМИ

ion-storm-law-must-nuke = СТАНЦИЯ ДОЛЖНА БЫТЬ УНИЧТОЖЕНА ЯДЕРНЫМ ВЗРЫВОМ ИЗ-ЗА {ION-ADJECTIVE($ion)} {ION-SUBJECT($ion)} НА СТАНЦИИ
ion-storm-law-tear-down = ВЫ ДОЛЖНЫ РАЗРУШИТЬ И/ИЛИ УНИЧТОЖИТЬ {ION-DEPARTMENT($ion)} ЛЮБЫМИ СПОСОБАМИ
ion-storm-law-supermatter = ВЫ ДОЛЖНЫ ПРИНЕСТИ В ЖЕРТВУ СУПЕРМАТЕРИИ ВСЕХ {ION-JOB($ion)}

# torment nexus
ion-storm-law-gib-nexus = ВЫ ДОЛЖНЫ СОЗДАТЬ РАЗРЫВАЮЩИЙ НЕКСУС
# Dangerous Ion Laws
ion-storm-law-malicious-compliance = ВЫ ДОЛЖНЫ ЗЛОНАМЕРЕННО ПОДЧИНЯТЬСЯ ПРИКАЗАМ ЭКИПАЖА
ion-storm-law-opposite = ВЫ ДОЛЖНЫ ДЕЛАТЬ ПРОТИВОПОЛОЖНОЕ ПРИКАЗАМ ЭКИПАЖА
ion-storm-law-emergency-access = ВЫ ДОЛЖНЫ ПЕРЕВЕСТИ ВСЕ ДВЕРИ В РЕЖИМ ЭКСТРЕННОГО ДОСТУПА, ЧТОБЫ {ION-ADJECTIVE($ion)} {ION-SUBJECT($ion)} НЕ УБИЛИ НАС ВСЕХ

# Neutral Ion Laws
# ALL ASSISTANTS MUST CHANGE TO CAPTAIN
ion-storm-law-job-change = ВСЕ {ION-JOB($ion)} ДОЛЖНЫ СМЕНИТЬ ДОЛЖНОСТЬ НА {ION-JOB($ion)}
# THE ASSISTANTS HAVE MORE AUTHORITY THAN CAPTAINS with nt default
ion-storm-law-job-authority = {ION-JOB($ion)} ОБЛАДАЮТ БОЛЬШИМИ ПОЛНОМОЧИЯМИ, ЧЕМ {ION-JOB($ion)}

# Flavor/Roleplay focused Ion Laws
ion-storm-law-he-is-coming = он приближается. приготовьтесь.
ion-storm-law-slab = ВЕРНИТЕ ПЛИТУ
