criminal-records-status-brutalize = Избить

criminal-records-console-brutalize-reason = Причина избиения

criminal-records-console-brutalize = {$officer} отметил {$name} ({$job}) для избиения по причине: {$reason}
criminal-records-console-not-brutalize = {$officer} отметил, что {$name} ({$job}) избит(а) достаточно.

criminal-records-status-demote = Понизить

criminal-records-console-demote-reason = Причина понижения

criminal-records-console-demote = {$officer} отметил {$name} ({$job}) для понижения по причине: {$reason}
criminal-records-console-not-demote = {$officer} отметил, что {$name} ({$job}) больше не помечен(а) для понижения.
